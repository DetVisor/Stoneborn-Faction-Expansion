<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <SitePartDef>
    <defName>LTS_StonebornVaultSite</defName>
    <label>stoneborn ruins</label>
    <description>A ruined site.</description>
    <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
    <expandingIconTexture>World/StonebornRuin</expandingIconTexture>
    <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
    <gravShipsCanLandOn>true</gravShipsCanLandOn>
    <tags>
      <li>LTS_StonebornVaultSite</li>
    </tags>
  </SitePartDef>

  <GenStepDef>
    <defName>LTS_StonebornVaultSite</defName>
    <linkWithSite>LTS_StonebornVaultSite</linkWithSite>
    <order>460</order>
    <genStep Class="KCSG.GenStep_CustomStructureGen">
      <structureLayoutDefs>
        <li>LTS_StonebornVaultSiteTest</li>
		
      </structureLayoutDefs>

      <fullClear>false</fullClear>      <!-- Clear any impassable in the way -->
      <clearFogInRect>false</clearFogInRect>      <!-- Clear fog on the structure -->
      <preventBridgeable>true</preventBridgeable>      <!-- Prevent lake/river/marsh (bridgeable) -->
    </genStep>
  </GenStepDef>
  
  <MapGeneratorDef>
    <defName>LTS_StonebornVault</defName>
    <label>ancient stoneborn vault</label>
    <isUnderground>true</isUnderground>
    <disableCallAid>true</disableCallAid>
    <pocketMapProperties>
      <biome>Underground</biome>
      <temperature>15</temperature>
      <canBeCleaned>true</canBeCleaned>
    </pocketMapProperties>
    <genSteps>
      <li>ElevationFertility</li>
      <li>Underground_RocksFromGrid</li>
      <li>Terrain</li>
      <li>RockChunks</li>
      
	  <li>LTS_StonebornVault</li>
	  
      <li>LTS_StonebornVaultFindPlayerStartSpot</li>
	  
	  <li>Fog</li>
    </genSteps>
  </MapGeneratorDef>
  
  <GenStepDef>
    <defName>LTS_StonebornVault</defName>
    <order>551</order><!--fog is 1500, so this just needs to be before that-->
    <genStep Class="KCSG.GenStep_CustomStructureGen">
      <structureLayoutDefs>
        <li>LTS_StonebornVaultTest</li>
      </structureLayoutDefs>
      <fullClear>true</fullClear>      <!-- Clear any impassable in the way -->
      <clearFogInRect>false</clearFogInRect>      <!-- Clear fog on the structure -->
      <preventBridgeable>true</preventBridgeable>      <!-- Prevent lake/river/marsh (bridgeable) -->
    </genStep>
  </GenStepDef>
  
  <GenStepDef>
    <defName>LTS_StonebornVaultFindPlayerStartSpot</defName>
    <order>552</order>
    <genStep Class="LTS_StonebornSiteGeneration.LTS_GenStep_FindStart"/>
  </GenStepDef>

