    <defName>DV_DwarvenCrate</defName>
    <label>dwarven crate</label>
    <description>A self-powered hermetically-sealed crate for preserving valuable items. These can preserve their contents for a long time.</description>
    <size>(1, 1)</size>
    <fillPercent>0.40</fillPercent>
    <rotatable>false</rotatable>
    <graphicData>
      <texPath>Things/Building/Ruins/DwarvenCrate</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2, 2)</drawSize>
      <shadowData>
        <volume>(0.8, 0.8, 0.8)</volume>
      </shadowData>
    </graphicData>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
    </statBases>
    <interactionCellOffset>(0,0,0)</interactionCellOffset>
    <building>
      <openingEffect>DV_HermeticCanisterOpened</openingEffect>
    </building>
    <comps>
      <li Class="CompProperties_EmptyStateGraphic">
        <graphicData>
          <texPath>Things/Building/Ruins/DwarvenCrateEmpty</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <drawSize>(2, 2)</drawSize>
        </graphicData>
      </li>
    </comps>
    <tickerType>Normal</tickerType>
  </ThingDef>


  <ThingDef ParentName="BuildingBase">
    <defName>DV_TremorbrewBarrel</defName>
    <label>tremorbrew barrel</label>
    <description>An ancient, broken barrel that looks like it once contained waste of some sort. The only thing it contains now is a smear of dried sludge.</description>
    <rotatable>false</rotatable>
    <thingCategories>
      <li>BuildingsSecurity</li>
    </thingCategories>
    <graphicData>
      <texPath>Things/Building/Ruins/TremorbrewBarrel</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(2, 2)</drawSize>
      <shadowData>
        <volume>(0.7, 0.5, 0.7)</volume>
      </shadowData>
    </graphicData>
    <size>(1, 1)</size>
    <fillPercent>0.30</fillPercent>
    <altitudeLayer>Building</altitudeLayer>
    <minifiedDef>MinifiedThing</minifiedDef>
    <statBases>
      <Mass>6</Mass>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>200</WorkToBuild>
      <Flammability>1</Flammability>
    </statBases>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <tickerType>Normal</tickerType>
    <comps>
      <li Class="CompProperties_Explosive">
        <wickTicks>300</wickTicks>
        <explosiveRadius>3.9</explosiveRadius>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <explodeOnKilled>true</explodeOnKilled>
        <startWickHitPointsPercent>0.9</startWickHitPointsPercent>
        <drawWick>true</drawWick>
        <preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef>
        <startWickOnDamageTaken>
          <li>Flame</li>
          <li>Bomb</li>
          <li>Bullet</li>
          <li>Arrow</li>
          <li>ArrowHighVelocity</li>
        </startWickOnDamageTaken>
      </li>
      <li Class="CompProperties_InspectString">
        <inspectString>Can be triggered to explode.</inspectString>
      </li>
      <li Class="CompProperties_Usable">
        <useJob>TriggerObject</useJob>
        <useLabel>Trigger {0_label}</useLabel>
      </li>
      <li Class="CompProperties_UseEffect">
        <compClass>CompUseEffect_StartWick</compClass>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>1</glowRadius>
        <glowColor>(255,7,7,0)</glowColor>
      </li>
    </comps>
  </ThingDef>


</Defs>