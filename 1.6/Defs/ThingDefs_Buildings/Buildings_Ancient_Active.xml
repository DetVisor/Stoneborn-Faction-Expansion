<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>DV_DwarvenGrate</defName>
    <label>grate</label>
    <description>A vent for equalizing the temperature between two rooms without allowing people to walk between them.</description>
    <graphicData>
      <texPath>Things/Building/Ruins/Traps/Grate</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <startingHpRange>0.5~1.3</startingHpRange>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>200</pathCost>
    <blockWind>true</blockWind>
    <fillPercent>0.5</fillPercent>
    <coversFloor>true</coversFloor>
    <blockLight>true</blockLight>
    <blockWeather>true</blockWeather>
    <castEdgeShadows>true</castEdgeShadows>
    <canOverlapZones>false</canOverlapZones>
    <staticSunShadowHeight>1.0</staticSunShadowHeight>
    <statBases>
      <WorkToBuild>400</WorkToBuild>
      <MaxHitPoints>100</MaxHitPoints>
      <Flammability>1.0</Flammability>
    </statBases>
    <tickerType>Rare</tickerType>
    <costList>
      <DV_Mithrium>2</DV_Mithrium>
    </costList>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <building>
      <canPlaceOverWall>true</canPlaceOverWall>
      <canExchangeVacuum>true</canExchangeVacuum>
      <isAirtight>false</isAirtight>
    </building>
  </ThingDef>


  <ThingDef ParentName="BuildingBase">
    <defName>DV_Dwarven_Spikes</defName>
    <label>spike trap</label>
    <thingClass>ThingWithComps</thingClass>
    <description>An ancient stoneborn brazier, made from mithrium.</description>
    <noRightClickDraftAttack>true</noRightClickDraftAttack>
    <graphicData>
      <texPath>Things/Building/Ruins/Traps/SpikeTrap</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <startingHpRange>0.5~1.3</startingHpRange>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>400</WorkToBuild>
      <TrapMeleeDamage>100</TrapMeleeDamage>
      <TrapSpringChance>1.0</TrapSpringChance>
    </statBases>
    <selectable>false</selectable>
    <tickerType>Normal</tickerType>
    <fillPercent>0.25</fillPercent>
    <passability>Standable</passability>
    <pathCost>42</pathCost>
    <blockWind>true</blockWind>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <rotatable>false</rotatable>
    <costList>
      <DV_Mithrium>2</DV_Mithrium>
    </costList>
    <building>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
      <isTrap>true</isTrap>
      <trapDestroyOnSpring>false</trapDestroyOnSpring>
      <trapDamageCategory>Sharp</trapDamageCategory>
      <expandHomeArea>false</expandHomeArea>
      <ai_chillDestination>false</ai_chillDestination>
    </building>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>DV_Dwarven_FreezeVent</defName>
    <label>freeze vent</label>
    <thingClass>ThingWithComps</thingClass>
    <description>An ancient stoneborn brazier, made from mithrium.</description>
    <noRightClickDraftAttack>true</noRightClickDraftAttack>
    <graphicData>
      <texPath>Things/Building/Ruins/Traps/FreezeVent</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <startingHpRange>0.5~1.3</startingHpRange>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>400</WorkToBuild>
    </statBases>
    <selectable>false</selectable>
    <tickerType>Normal</tickerType>
    <fillPercent>0.25</fillPercent>
    <passability>PassThroughOnly</passability>
    <pathCost>42</pathCost>
    <blockWind>true</blockWind>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <rotatable>false</rotatable>
    <costList>
      <DV_Mithrium>2</DV_Mithrium>
    </costList>
    <building>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
      <isInert>false</isInert>
      <ai_chillDestination>false</ai_chillDestination>
      <canLandGravshipOn>true</canLandGravshipOn>
    </building>
    <comps>
      <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusher</compClass>
        <heatPerSecond>-50</heatPerSecond>
      </li>
      <li Class="CompProperties_Effecter">
        <effecterDef>DV_FreezeReleasing</effecterDef>
      </li>
    </comps>
  </ThingDef>

