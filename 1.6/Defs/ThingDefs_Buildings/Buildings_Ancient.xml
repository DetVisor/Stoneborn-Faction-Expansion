<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>DV_Dwarven_RuinedChair</defName>
    <label>ruined chair</label>
    <thingClass>Building</thingClass>
    <category>Building</category>
    <description>An ancient stoneborn chair, made from mithrium.</description>
    <noRightClickDraftAttack>true</noRightClickDraftAttack>
    <graphicData>
      <texPath>Things/Building/Ruins/Ruined_DwarvenChair/Ruined_DwarvenChair</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <color>(107, 100, 90)</color>
      <drawSize>(1,1)</drawSize>
      <shadowData>
        <volume>(0.76,0.3,0.15)</volume>
        <offset>(0,0,-0.39)</offset>
      </shadowData>
      <damageData>
        <rectN>(0,0,1,0.703125)</rectN>
        <rectS>(0.09375,0,0.84375,1)</rectS>
        <rectE>(0,0,0.84375,0.625)</rectE>
        <rectW>(0.15625,0,0.84375,0.625)</rectW>
      </damageData>
    </graphicData>
    <startingHpRange>0.9~1.3</startingHpRange>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>400</WorkToBuild>
    </statBases>
    <fillPercent>0.25</fillPercent>
    <passability>PassThroughOnly</passability>
    <pathCost>42</pathCost>
    <blockWind>true</blockWind>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <rotatable>false</rotatable>
    <costList>
      <DV_Mithrium>30</DV_Mithrium>
    </costList>
    <building>
      <isInert>true</isInert>
      <ai_chillDestination>false</ai_chillDestination>
      <canLandGravshipOn>true</canLandGravshipOn>
    </building>
  </ThingDef>

  <ThingDef ParentName="DoorBase">
    <defName>DV_Dwarven_RuinedGate</defName>
    <label>ruined gate</label>
    <description>Divides rooms. A rustic wooden door decorated in a dwarven style. This large, heavy door requires adjacent walls to function.</description>
    <thingClass>Building_MultiTileDoor</thingClass>
    <canGenerateDefaultDesignator>false</canGenerateDefaultDesignator>
    <statBases>
      <WorkToBuild>15000</WorkToBuild>
      <MaxHitPoints>250</MaxHitPoints>
      <Beauty>30</Beauty>
    </statBases>
    <costList>
      <DV_Mithrium>30</DV_Mithrium>
    </costList>
    <graphicData>
      <texPath>Things/Building/Ruins/Dwarven_RuinedGates/DwarvenGate2x1_Mover</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <color>(107, 100, 90)</color>
      <damageData>
        <enabled>false</enabled>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/Ruins/Dwarven_RuinedGates/DwarvenGate2x1_Mover</uiIconPath>
    <useBlueprintGraphicAsGhost>true</useBlueprintGraphicAsGhost>
    <size>(2, 1)</size>
    <rotatable>true</rotatable>
    <constructionSkillPrerequisite>5</constructionSkillPrerequisite>
    <building>
      <blueprintClass>Blueprint_Build</blueprintClass>
      <blueprintGraphicData>
        <texPath>Things/Building/Ruins/Dwarven_RuinedGates/DwarvenGate2x1_Mover</texPath>
        <graphicClass>Graphic_Multi</graphicClass>
        <shaderType>EdgeDetect</shaderType>
        <drawSize>(2.6, 2.8)</drawSize>
      </blueprintGraphicData>
      <isSupportDoor>true</isSupportDoor>
      <doorTopGraphic>
        <texPath>Things/Building/Ruins/Dwarven_RuinedGates/DwarvenGate2x1_Top</texPath>
        <graphicClass>Graphic_Multi</graphicClass>
        <drawSize>(3.1, 2.1)</drawSize>
      </doorTopGraphic>
      <doorSupportGraphic>
        <texPath>Things/Building/Ruins/Dwarven_RuinedGates/DwarvenGate2x1_Support</texPath>
        <graphicClass>Graphic_Multi</graphicClass>
        <drawSize>(3.1, 2.1)</drawSize>
      </doorSupportGraphic>
    </building>
    <designationHotKey>Misc3</designationHotKey>
    <placeWorkers>
    </placeWorkers>
  </ThingDef>

